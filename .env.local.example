# ============================================
# PontoWebDesk - Environment Variables (Frontend/Full)
# ============================================
#
# ⚠️  INSTRUÇÕES DE SEGURANÇA CRÍTICAS:
# 1. NUNCA commite o arquivo .env.local real no Git
# 2. Este arquivo é um TEMPLATE - use valores fictícios abaixo
# 3. SUPABASE_SERVICE_ROLE_KEY NUNCA deve ir para o frontend!
# 4. Gere chaves fortes únicas para cada ambiente
#
# ============================================

# Google Gemini API Key (para insights de IA)
# Obtenha em: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here
# Opcional — padrão no app: gemini-1.5-flash
# VITE_GEMINI_MODEL=gemini-1.5-flash

# Firebase Configuration
# Obtenha em: https://console.firebase.google.com/
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Firebase Emulator (opcional - desenvolvimento local)
# VITE_USE_FIREBASE_EMULATOR=false
# VITE_FIREBASE_EMULATOR_HOST=localhost
# VITE_FIREBASE_EMULATOR_PORT=9099

# URL do app (recomendado em dev para auth/redirect)
# VITE_APP_URL=http://localhost:3010

# Supabase (obrigatório para o app)
# URL pública do projeto Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
# Anon Key - pode ser exposta no frontend (RLS protege os dados)
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# audit_logs inclui tenant_id? (prioridade sobre deteção via information_schema)
# true|false — omitir para deteção automática
# VITE_HAS_AUDIT_LOGS_TENANT_ID=false

# Sentry (opcional - error tracking)
# VITE_SENTRY_DSN=https://xxx@yyy.ingest.sentry.io/zzz

# Environment
VITE_APP_ENV=development
# VITE_APP_ENV=production

# ========== APIs Serverless (obrigatório para /api/* e cron) ==========
# Gere uma chave forte: openssl rand -hex 32
# Use a mesma chave em API_KEY e CRON_SECRET no Vercel
API_KEY=generate_strong_random_key_here
CRON_SECRET=generate_strong_random_key_here

# Chave específica para relógios REP (opcional, usa API_KEY se vazio)
# REP_API_KEY=your_rep_specific_key_here

# ========== AGENTE LOCAL (clock-sync-agent) ==========
# ⚠️  SUPABASE_SERVICE_ROLE_KEY NUNCA no frontend!
# Use APENAS no agente local ou backend seguro.
#
# Modo API intermediária (RECOMENDADO):
CLOCK_AGENT_API_URL=http://localhost:3000
CLOCK_AGENT_API_KEY=use_mesmo_valor_de_API_KEY_acima

# Modo direto (LEGACY - menos seguro, use apenas se necessário)
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# SUPABASE_URL=${VITE_SUPABASE_URL}

# Intervalo de sync do agente (ms). Default: 10000 (10s)
# CLOCK_AGENT_INTERVAL_MS=10000

# SQLite local: onde salvar a fila offline. Default: agent/data/pending.db
# CLOCK_AGENT_SQLITE_PATH=agent/data/pending.db

# ========== Segurança Adicional ==========
# Chave para assinatura de timestamps (obrigatória)
# Gere com: openssl rand -hex 32
TIMESTAMP_SECRET_KEY=generate_strong_random_key_here

# URLs permitidas para CORS (separadas por vírgula)
# Deixe vazio para permitir apenas a origem do request (dinâmico)
# CORS_ALLOWED_ORIGINS=https://app.seudominio.com,https://admin.seudominio.com

# ========== Rate Limiting ==========
# Requisições por minuto por IP (default: 100)
# RATE_LIMIT_PER_MINUTE=100
# Requisições por minuto para login (default: 5)
# RATE_LIMIT_LOGIN_PER_MINUTE=5
