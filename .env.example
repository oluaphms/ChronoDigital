# ============================================
# PontoWebDesk - Environment Variables (Backend)
# ============================================
#
# ⚠️  INSTRUÇÕES DE SEGURANÇA:
# 1. NUNCA commite o arquivo .env real no Git
# 2. Este arquivo (.env.example) é um TEMPLATE - use valores fictícios
# 3. Gere novas chaves para produção: https://supabase.com/dashboard/project/_/settings/api
# 4. Roteie chaves imediatamente se houver exposição acidental
#
# ============================================

# Supabase Configuration
# URL do projeto Supabase (ex: https://xyz123.supabase.co)
SUPABASE_URL=https://your-project.supabase.co

# Service Role Key - NUNCA exponha no frontend! Apenas backend/serverless.
# Gerar em: Supabase Dashboard > Project Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
